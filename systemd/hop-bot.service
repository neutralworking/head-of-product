[Unit]
Description=HoP Discord bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/head-of-product
EnvironmentFile=/opt/head-of-product/.env
ExecStart=/opt/head-of-product/.venv/bin/python -m agents.discord_bot
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
